# ============================================================
# Agentic Workflow Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# The engine loads .env automatically via python-dotenv.
# ============================================================



# LLM PROVIDER : SO THAT IT CAN BE CONFIGURABLE
# LLM_PROVIDER      – "gemini" | "openai" | "anthropic"  (default: "gemini")
LLM_PROVIDER=openai

# --- GitHub (data source) ---
# Personal access token — optional for public repos, but
# unauthenticated requests are limited to 60/hour.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=githubToken

# --- Anthropic Claude (LLM reasoning) ---
# API key from: https://console.anthropic.com/
# Required for both planning and summarization steps.
GEMINI_API_KEY=GEMINI_API_KEY
OPENAI_API_KEY=openai_API_key

# --- Email / SMTP (delivery) ---
# Works with any SMTP provider (Gmail, Outlook, AWS SES, etc.)
# For Gmail: use an App Password, not your regular password.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=user_email@gmail.com
SMTP_PASSWORD=appPasssword
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=team@example.com
